# Environment Configuration
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# For production
PRODUCTION_URL=https://master.traffic2umarketing.com

# Database
DATABASE_PATH=./db.sqlite

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ENCRYPTION_KEY=your-32-character-encryption-key-!

# Redis (for job queue - optional, can use in-memory fallback)
REDIS_URL=redis://localhost:6379

# API Keys and OAuth Credentials
# Facebook/Instagram
FACEBOOK_APP_ID=your-app-id
FACEBOOK_APP_SECRET=your-app-secret
FACEBOOK_GRAPH_API_VERSION=v18.0

# YouTube
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret

# TikTok
TIKTOK_CLIENT_KEY=your-client-key
TIKTOK_CLIENT_SECRET=your-client-secret
TIKTOK_API_KEY=your-api-key

# Claude AI (for content generation)
CLAUDE_API_KEY=your-claude-api-key

# Veed.io (for video creation)
VEED_API_KEY=your-veed-api-key

# Google Cloud (for various services)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_API_KEY=your-api-key

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Scheduler Settings
POSTING_CHECK_INTERVAL=300000
ENGAGEMENT_CHECK_INTERVAL=600000
ANALYTICS_UPDATE_INTERVAL=3600000

# Post Limits
MAX_ACCOUNTS_PER_POST=50
MAX_SCHEDULE_DAYS_AHEAD=365
MAX_AUTO_RESPONSE_RULES=100

# Auto-Response Settings
AUTO_RESPONSE_ENABLED=true
AUTO_RESPONSE_CHECK_INTERVAL=300000
AUTO_RESPONSE_RATE_LIMIT=10

# Growth Features Settings
AUTO_FOLLOW_ENABLED=false
AUTO_LIKE_ENABLED=false
AUTO_COMMENT_ENABLED=false
AUTO_FOLLOW_RATE_LIMIT=50
AUTO_LIKE_RATE_LIMIT=100
AUTO_COMMENT_RATE_LIMIT=20

# Video Settings
VIDEO_QUALITY=1080p
VIDEO_TIMEOUT=300000
MAX_VIDEO_SIZE=104857600

# Thumbnail Settings
THUMBNAIL_WIDTH=1280
THUMBNAIL_HEIGHT=720
THUMBNAIL_FORMAT=png

# Analytics
ANALYTICS_RETENTION_DAYS=365
ANALYTICS_UPDATE_FREQUENCY=hourly

# Email (optional, for notifications)
EMAIL_SERVICE=disabled
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Slack (optional, for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000

# Backup Settings
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
